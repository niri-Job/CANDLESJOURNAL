# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Encryption — must match ENCRYPTION_KEY in your Next.js .env.local
ENCRYPTION_KEY=your-32-character-encryption-key-here

# MetaAPI — get token from https://app.metaapi.cloud/token
METAAPI_TOKEN=your-metaapi-auth-token-here

# MetaAPI API base URLs (optional — defaults below are correct for most users)
# If MetaAPI assigns your account to a specific region, update METAAPI_CLIENT_URL
# to use that region's domain (e.g. mt-client-api-v1.new-york.agiliumtrade.ai).
# Check the MetaAPI dashboard or SDK docs for your account's region.
METAAPI_PROVISIONING_URL=https://mt-provisioning-api-v1.agiliumtrade.agiliumtrade.ai
METAAPI_CLIENT_URL=https://mt-client-api-v1.agiliumtrade.agiliumtrade.ai
